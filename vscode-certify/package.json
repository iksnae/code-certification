{
  "name": "certify-vscode",
  "displayName": "Certify",
  "description": "Code trust, with an expiration date — view report cards, configure AI providers, run certification",
  "version": "0.3.0",
  "publisher": "iksnae",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1C1C1C",
    "theme": "dark"
  },
  "homepage": "https://iksnae.github.io/code-certification/",
  "bugs": {
    "url": "https://github.com/iksnae/code-certification/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/iksnae/code-certification"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "keywords": [
    "certification",
    "code quality",
    "report card",
    "linting",
    "AI review",
    "code governance",
    "continuous certification"
  ],
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.certification/config.yml",
    "workspaceContains:.gitmodules",
    "onView:certifyUnits",
    "onCommand:certify.init",
    "onCommand:certify.openDashboard",
    "onCommand:certify.scan",
    "onCommand:certify.certify",
    "onCommand:certify.report",
    "onCommand:certify.configureProvider",
    "onCommand:certify.listModels",
    "onCommand:certify.testConnection",
    "onCommand:certify.installCLI",
    "onCommand:certify.workspaceScan",
    "onCommand:certify.workspaceCertify",
    "onCommand:certify.workspaceReport",
    "onCommand:certify.architect",
    "onCommand:certify.openArchitectReview"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "certify.init",
        "title": "Certify: Initialize Repository",
        "icon": "$(add)"
      },
      {
        "command": "certify.scan",
        "title": "Certify: Scan Repository",
        "icon": "$(search)"
      },
      {
        "command": "certify.certify",
        "title": "Certify: Run Certification",
        "icon": "$(shield)"
      },
      {
        "command": "certify.report",
        "title": "Certify: Generate Report",
        "icon": "$(graph)"
      },
      {
        "command": "certify.openDashboard",
        "title": "Certify: Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "certify.configureProvider",
        "title": "Certify: Configure AI Provider",
        "icon": "$(gear)"
      },
      {
        "command": "certify.listModels",
        "title": "Certify: Browse Available Models"
      },
      {
        "command": "certify.testConnection",
        "title": "Certify: Test Provider Connection"
      },
      {
        "command": "certify.installCLI",
        "title": "Certify: Install CLI"
      },
      {
        "command": "certify.architect",
        "title": "Certify: Run Architect Review",
        "icon": "$(beaker)"
      },
      {
        "command": "certify.openArchitectReview",
        "title": "Certify: Open Architect Review",
        "icon": "$(book)"
      },
      {
        "command": "certify.openUnit",
        "title": "Certify: Go to Unit Source"
      },
      {
        "command": "certify.workspaceScan",
        "title": "Certify: Scan Workspace",
        "icon": "$(search)"
      },
      {
        "command": "certify.workspaceCertify",
        "title": "Certify: Certify Workspace",
        "icon": "$(shield)"
      },
      {
        "command": "certify.workspaceReport",
        "title": "Certify: Workspace Report",
        "icon": "$(graph)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "certifyUnits",
          "name": "Certify"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "certify.scan",
          "when": "view == certifyUnits && !certify:isWorkspace",
          "group": "navigation"
        },
        {
          "command": "certify.certify",
          "when": "view == certifyUnits && !certify:isWorkspace",
          "group": "navigation"
        },
        {
          "command": "certify.openDashboard",
          "when": "view == certifyUnits && certify:hasData",
          "group": "navigation"
        },
        {
          "command": "certify.workspaceScan",
          "when": "view == certifyUnits && certify:isWorkspace",
          "group": "navigation"
        },
        {
          "command": "certify.workspaceCertify",
          "when": "view == certifyUnits && certify:isWorkspace",
          "group": "navigation"
        },
        {
          "command": "certify.workspaceReport",
          "when": "view == certifyUnits && certify:isWorkspace",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Certify",
      "properties": {
        "certify.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show certification grades inline on functions"
        },
        "certify.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to certify binary (auto-detected if empty)"
        },
        "certify.provider.preset": {
          "type": "string",
          "default": "",
          "enum": ["", "OpenRouter", "Groq", "Together", "Fireworks", "OpenAI", "Google AI Studio", "Ollama", "LM Studio", "vLLM", "Custom"],
          "enumDescriptions": [
            "No preset selected",
            "Access 200+ models including GPT-4o, Claude, Gemini, Llama, Qwen, Mistral",
            "Ultra-fast inference — Llama, Gemma, Mixtral (generous free tier)",
            "Llama, Qwen, DeepSeek, Mixtral",
            "Llama, Qwen, Mixtral, custom fine-tunes",
            "GPT-4o, GPT-4o-mini, o1",
            "Gemini 2.0 Flash, Gemini Pro",
            "Run any model locally — Qwen, Llama, Phi, Gemma, DeepSeek",
            "Local model server with GUI model management",
            "High-performance local inference server",
            "Any OpenAI-compatible API endpoint"
          ],
          "markdownDescription": "Quick-select an AI provider preset. Automatically fills in **Base URL** and **API Key Env Var**."
        },
        "certify.provider.baseUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "API base URL for the AI provider (e.g., `https://openrouter.ai/api/v1`). Auto-filled when selecting a preset."
        },
        "certify.provider.apiKeyEnvVar": {
          "type": "string",
          "default": "",
          "markdownDescription": "Environment variable name containing the API key (e.g., `OPENROUTER_API_KEY`). Leave empty for local providers."
        },
        "certify.agent.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI-assisted certification reviews"
        },
        "certify.agent.model": {
          "type": "string",
          "default": "",
          "markdownDescription": "Model ID to use for AI reviews (e.g., `qwen/qwen3-coder`). Use **Certify: Browse Models** to discover available models."
        },
        "certify.agent.strategy": {
          "type": "string",
          "default": "conservative",
          "enum": ["conservative", "standard", "full"],
          "enumDescriptions": [
            "Prescreen only — fastest, lowest cost",
            "3-stage pipeline — prescreen, review, scoring",
            "5-stage pipeline — all stages including deep review and remediation"
          ],
          "description": "AI review strategy controlling depth and cost"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "tsc --noEmit",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies",
    "publish": "npm run build && npx @vscode/vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  }
}
